# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# .env / .env*.local stay ignored (secrets). Templates and the dev-shared
# defaults are committed: .env.example, .env.development, .env.production.
.env*
!**/.env.example
!.env.development
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
project_status.md

# Python / FastAPI backend
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
dist/
build/
*.egg
google_maps_data

# Playwright MCP runtime artefacts
/.playwright-mcp/
# Screenshots captured during dev/Playwright sessions
/*.png
# Claude Code state.
# Track shared project state (skills, agents, memory, plans) so the next
# machine can pick up where the previous left off. Ignore local-only files
# like settings.local.json (may include dev DB URLs) and any caches.
.claude/*
!.claude/README.md
!.claude/skills/
!.claude/agents/
!.claude/agent-memory/
!.claude/memory/
!.claude/plans/