# Frontend dev defaults (committed, no secrets).
# Loaded automatically by `npm run dev`.
# Override these locally in `.env.development.local` (gitignored).

# Backend runs in Docker on host port 8002 (compose maps :8002 -> :8000).
NEXT_PUBLIC_API_URL=http://localhost:8002

# When true, social features render mock data instead of hitting the backend.
NEXT_PUBLIC_SOCIAL_MOCK=true
