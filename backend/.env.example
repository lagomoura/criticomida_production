# Database
DATABASE_URL=postgresql+asyncpg://criticomida:criticomida_secret@db:5432/criticomida
POSTGRES_USER=criticomida
POSTGRES_PASSWORD=criticomida_secret
POSTGRES_DB=criticomida

# JWT (use >=32 random chars; never the placeholder in production)
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=criticomida-api
JWT_AUDIENCE=criticomida-clients
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
# Set true when serving the API over HTTPS (required for Secure cookies in prod)
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
