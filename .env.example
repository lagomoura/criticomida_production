# Template for frontend env. Copy what you need:
#   cp .env.example .env.development.local   # for dev secrets
# Vercel manages prod env vars via the dashboard, not via committed files.

# Backend API
# - Dev: http://localhost:8002 (set in .env.development)
# - Prod: https://<railway-domain>.up.railway.app (set in Vercel UI)
NEXT_PUBLIC_API_URL=http://localhost:8002

# When true, social features render mock data instead of hitting the backend.
NEXT_PUBLIC_SOCIAL_MOCK=true

# Google Maps (browser-exposed, NEXT_PUBLIC_*)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Image generation (fal.ai) — required for AI category images
FAL_KEY=

# Chat (litellm)
CHAT_MODEL=gemini/gemini-2.5-flash
CHAT_API_KEY=

# Sentry (FE).
# - NEXT_PUBLIC_SENTRY_DSN: DSN público del proyecto JS, seguro de exponer.
# - SENTRY_AUTH_TOKEN: token con scopes project:releases + org:read.
#   Solo se usa en build (Vercel) para subir source maps. Vacío en local
#   está OK: el build pasa sin upload de mapas.
# - SENTRY_ORG / SENTRY_PROJECT: slugs visibles en la URL del proyecto Sentry.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
